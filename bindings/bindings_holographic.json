{
  "bindings": {
    "/actions/main": {
      "sources": [
        {
          "path": "/user/hand/left/input/thumbstick",
          "mode": "joystick",
          "inputs": {
            "position": { "output": "/actions/main/in/LeftJoystick" }
          }
        },
        {
          "path": "/user/hand/right/input/thumbstick",
          "mode": "joystick",
          "inputs": {
            "position": { "output": "/actions/main/in/RightJoystick" }
          }
        },
        {
          "path": "/user/hand/left/input/grip",
          "mode": "trigger",
          "inputs": {
            "pull": { "output": "/actions/main/in/LeftGrip" }
          }
        },
        {
          "path": "/user/hand/right/input/grip",
          "mode": "trigger",
          "inputs": {
            "pull": { "output": "/actions/main/in/RightGrip" }
          }
        },
        {
          "path": "/user/hand/left/input/trigger",
          "mode": "trigger",
          "inputs": {
            "pull": { "output": "/actions/main/in/LeftTrigger" }
          }
        },
        {
          "path": "/user/hand/right/input/trigger",
          "mode": "trigger",
          "inputs": {
            "pull": { "output": "/actions/main/in/RightTrigger" }
          }
        }
      ]
    }
  },
  "controller_type": "holographic_controller",
  "description": "Bindings for WMR / Holographic Controllers",
  "name": "PolytoriaVR Holographic Bindings"
}
